<!--
This XML file declares which signature|privileged permissions should be granted to privileged
applications on GMS or Google-branded devices.
It allows additional grants on top of privapp-permissions-platform.xml
-->
<permissions>
  <privapp-permissions package="com.google.android.carriersetup">
    <permission name="android.permission.ACCESS_NETWORK_STATE"/>
    <permission name="android.permission.CHANGE_NETWORK_STATE"/>
    <permission name="android.permission.CONNECTIVITY_USE_RESTRICTED_NETWORKS"/>
    <permission name="android.permission.INTERNET"/>
    <permission name="android.permission.MANAGE_NETWORK_POLICY"/>
    <permission name="android.permission.MODIFY_PHONE_STATE"/>
    <permission name="android.permission.READ_PRIVILEGED_PHONE_STATE"/>
    <permission name="android.permission.POST_NOTIFICATIONS"/>
    <permission name="com.google.android.apps.carrier.log.permission.SEND_LOGS"/>
    <permission name="com.google.android.setupwizard.SETUP_COMPAT_SERVICE"/>
    <permission name="com.verizon.mips.services.RECEIVE_SUW_CARRIER_SCREENS_UPDATE"/>
    <permission name="com.google.android.setupdesign.lottieloadinglayout.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"/>
    <permission name="com.google.android.setupdesign.lottieloadinglayout.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"/>
  </privapp-permissions>
</permissions>
